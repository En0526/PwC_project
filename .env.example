# 複製為 .env 並填入
FLASK_SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///site.db

# Google AI Studio API Key（在 https://aistudio.google.com/apikey 取得）
GEMINI_API_KEY=your-gemini-api-key

# Agent 3（頁面區塊理解並對位「監測目標」→ 強化後再交給既有 Gemini 擷取）：預設啟用；設 0/false/off 則關閉
PAGE_TARGET_AGENT_ENABLED=1
# 可選；未設定時沿用 AI_SUMMARY_MODEL，再預設 gemini-1.5-flash
# PAGE_TARGET_AGENT_MODEL=gemini-1.5-flash
AI_SUMMARY_MODEL=gemini-1.5-flash

# 排程「輪詢」間隔（分鐘）：多久喚醒一次，檢查哪些訂閱已到期。必須不大於你在儀表板設的最短檢查間隔才會準時（例如訂閱設每分鐘 → 這裡請 <=1）。預設 1。
SCHEDULER_POLL_MINUTES=1
# 舊變數名，目前未用於排程 tick；保留避免誤刪舊 .env 時出錯
CHECK_INTERVAL_MINUTES=30

# Email 通知（可選）
# 有設定 SMTP_HOST 與 SMTP_FROM 後，偵測到變更會寄信到使用者註冊信箱
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com
SMTP_USE_TLS=1
AUTO_SEND_NOTIFICATION_REPORT=1
NOTIFICATION_REPORT_LIMIT=6
NOTIFICATION_REPORT_COOLDOWN_MINUTES=0

# SSL 憑證例外白名單（可選）
# 僅當網站憑證有問題、且你信任該網站時才填寫，例如：
# INSECURE_SSL_DOMAINS=www.ardf.org.tw
INSECURE_SSL_DOMAINS=
